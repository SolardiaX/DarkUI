local E, C, L = select(2, ...):unpack()

------------------------------------------------------------------------
-- Combat Text
------------------------------------------------------------------------

local module = E:Module("CombatText")
module:SetConfigKey("combattext")

local cfg = C.combattext

local GetTime = GetTime
local floor, format, abs, pcall, wipe, tinsert, tremove = math.floor, string.format, math.abs, pcall, wipe, tinsert, tremove
local UnitGUID, UnitName, UnitHealth, UnitHealthMax = UnitGUID, UnitName, UnitHealth, UnitHealthMax
local C_Spell_GetSpellTexture = C_Spell.GetSpellTexture
local C_Spell_GetSpellName = C_Spell.GetSpellName
local C_Spell_IsAutoAttackSpell = C_Spell.IsAutoAttackSpell
local C_Spell_IsRangedAutoAttackSpell = C_Spell.IsRangedAutoAttackSpell
local GetMoney = GetMoney

------------------------------------------------------------------------
-- Secret Value Safety
------------------------------------------------------------------------

local function isSafeNumber(v)
    if type(v) ~= "number" then
        return false
    end
    if issecretvalue then
        return not issecretvalue(v)
    end
    local ok = pcall(function()
        return v + 0
    end)
    return ok
end

local function isSafeString(v)
    if type(v) ~= "string" then
        return false
    end
    if issecretvalue then
        return not issecretvalue(v)
    end
    local ok = pcall(function()
        return v == ""
    end)
    return ok
end

